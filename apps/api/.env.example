# ---- AvaanaSpace API environment ----
NODE_ENV=development
PORT=4000

# Comma separated list of allowed web origins
CORS_ORIGIN=http://localhost:5173

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Database (Supabase / PostgreSQL) ----
# Leave DATABASE_URL empty to run with the in-memory store (great for local dev / demos).
DATABASE_URL=
# For Vercel/serverless use the Supabase pooled connection string.
# For local migrations, use the direct connection string.
# Example: postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_SSL=true

# ---- Supabase Storage (optional) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=avaanaspace

# ---- Mail (Nodemailer) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="AvaanaSpace <no-reply@avaanaspace.com>"

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
